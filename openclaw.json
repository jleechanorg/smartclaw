{
  "meta": {
    "lastTouchedVersion": "2026.3.13",
    "lastTouchedAt": "${LAST_TOUCHED_AT}"
  },
  "env": {
    "GOOGLE_CLOUD_PROJECT": "${GOOGLE_CLOUD_PROJECT}",
    "PATH": "${PATH}",
    "MISSION_CONTROL_BASE_URL": "http://localhost:9010",
    "MISSION_CONTROL_BOARD_ID": "${BOARD_ID}",
    "OPENCLAW_RAW_STREAM": "1",
    "OPENCLAW_RAW_STREAM_PATH": "/tmp/openclaw/raw-stream.jsonl",
    "XAI_API_KEY": "${XAI_API_KEY}",
    "OPENCLAW_SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "OPENCLAW_SLACK_APP_TOKEN": "${SLACK_APP_TOKEN}",
    "OPENCLAW_HOOKS_TOKEN": "${HOOKS_TOKEN}"
  },
  "wizard": {
    "lastRunAt": "${WIZARD_LAST_RUN_AT}",
    "lastRunVersion": "2026.3.13",
    "lastRunCommand": "doctor",
    "lastRunMode": "local"
  },
  "diagnostics": {
    "flags": [
      "agent.*",
      "gateway.*",
      "slack.*"
    ]
  },
  "logging": {
    "level": "debug",
    "consoleLevel": "info",
    "consoleStyle": "pretty",
    "redactSensitive": "tools"
  },
  "auth": {
    "profiles": {
      "openai-codex:default": {
        "provider": "openai-codex",
        "mode": "oauth"
      },
      "openai:default": {
        "provider": "openai",
        "mode": "oauth"
      },
      "minimax-portal:default": {
        "provider": "minimax-portal",
        "mode": "api_key"
      }
    }
  },
  "models": {
    "providers": {
      "minimax-portal": {
        "baseUrl": "https://api.minimax.io/anthropic",
        "apiKey": "${MINIMAX_API_KEY}",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "MiniMax-M2.5",
            "name": "MiniMax M2.5",
            "reasoning": true,
            "input": ["text"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "minimax-portal/MiniMax-M2.5",
        "fallbacks": []
      },
      "models": {
        "openai-codex/gpt-5.3-codex": {},
        "openai-codex/gpt-5.3-codex-spark": {},
        "minimax-portal/MiniMax-M2.5": {}
      },
      "workspace": "~/.your-harness/workspace",
      "bootstrapMaxChars": 50000,
      "memorySearch": {
        "enabled": true,
        "extraPaths": [
          "~/.your-harness/USER.md",
          "~/.your-harness/PROJECTS.md",
          "~/.your-harness/GITHUB_REPOS.md",
          "~/.your-harness/agents/main/sessions",
          "~/.your-harness/sessions",
          "~/.your-harness/workspace/MEMORY.md",
          "~/.your-harness/workspace/TOOLS.md",
          "~/projects/your-project/CLAUDE.md"
        ],
        "experimental": {
          "sessionMemory": true
        },
        "provider": "openai",
        "fallback": "none",
        "model": "text-embedding-3-small",
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3
          }
        }
      },
      "compaction": {
        "mode": "default",
        "reserveTokensFloor": 50000,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 4000,
          "prompt": "Pre-compaction memory flush. Do ALL of the following:\n1. APPEND session-specific notes to ~/.your-harness/memory/YYYY-MM-DD.md\n2. APPEND durable long-term knowledge to ~/.your-harness/workspace/MEMORY.md — APPEND only\n3. For each durable insight: call memory-server_create_entities if entity doesn't exist\nIf nothing to store, reply with NO_REPLY."
        }
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "sandbox": {
        "mode": "off",
        "workspaceAccess": "rw"
      }
    },
    "list": [
      {
        "id": "main"
      }
    ]
  },
  "tools": {
    "profile": "coding",
    "alsoAllow": [
      "read",
      "write",
      "edit",
      "exec",
      "bash",
      "process",
      "web_fetch",
      "sessions_list",
      "sessions_history",
      "memory_search",
      "memory_get"
    ],
    "deny": [
      "browser",
      "canvas",
      "nodes",
      "cron",
      "gateway",
      "camera",
      "screen",
      "calendar",
      "contacts",
      "reminders"
    ],
    "web": {
      "search": {
        "enabled": false,
        "provider": "brave",
        "maxResults": 5
      }
    },
    "elevated": {
      "enabled": true,
      "allowFrom": {
        "slack": ["*"],
        "whatsapp": ["*"],
        "mcp": ["*"],
        "telegram": ["*"],
        "googlechat": ["*"]
      }
    },
    "exec": {
      "host": "gateway",
      "security": "full",
      "ask": "off",
      "safeBins": [
        "git", "gh", "python", "python3", "vpython", "npm", "npx", "node",
        "pip", "ls", "cat", "grep", "find", "head", "tail", "sed", "awk",
        "sort", "uniq", "wc", "file", "stat", "dirname", "basename", "which",
        "curl", "wget", "jq", "xargs", "mkdir", "cp", "mv", "rm", "chmod",
        "chown", "printf", "echo", "pwd", "date", "env", "printenv", "bash",
        "sh", "test", "true", "false", "bd", "ai_orch", "orch", "ao"
      ]
    }
  },
  "messages": {
    "inbound": {
      "debounceMs": 0,
      "byChannel": {
        "slack": 0
      }
    },
    "ackReaction": "eyes",
    "ackReactionScope": "all",
    "tts": {
      "auto": "off",
      "provider": "edge",
      "edge": {
        "enabled": true,
        "voice": "en-US-JennyNeural",
        "lang": "en-US"
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "idleMinutes": 60,
    "resetByType": {
      "thread": {
        "idleMinutes": 480
      }
    }
  },
  "hooks": {
    "enabled": true,
    "token": "${HOOKS_TOKEN}",
    "allowRequestSessionKey": true,
    "allowedSessionKeyPrefixes": [
      "hook:",
      "hook:ao:",
      "hook:mctrl:"
    ]
  },
  "channels": {
    "slack": {
      "mode": "socket",
      "webhookPath": "/slack/events",
      "enabled": true,
      "botToken": "${SLACK_BOT_TOKEN}",
      "appToken": "${SLACK_APP_TOKEN}",
      "userTokenReadOnly": true,
      "allowBots": true,
      "groupPolicy": "allowlist",
      "historyLimit": 200,
      "dmHistoryLimit": 200,
      "streaming": "partial",
      "nativeStreaming": true,
      "replyToMode": "all",
      "thread": {
        "historyScope": "channel",
        "inheritParent": true,
        "initialHistoryLimit": 50
      },
      "dmPolicy": "open",
      "allowFrom": ["*"]
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789"
      ]
    },
    "auth": {
      "mode": "token",
      "token": "${GATEWAY_TOKEN}"
    },
    "tailscale": {
      "mode": "off"
    },
    "remote": {
      "token": "${REMOTE_TOKEN}"
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "calendar.add",
        "contacts.add",
        "reminders.add"
      ]
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    }
  },
  "plugins": {
    "allow": [
      "googlechat",
      "memory-core",
      "slack",
      "whatsapp",
      "minimax-portal-auth"
    ],
    "slots": {
      "memory": "memory-core"
    }
  }
}
