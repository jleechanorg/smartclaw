diff --git a/scripts/ao-pr-poller-resume-tests.sh b/scripts/ao-pr-poller-resume-tests.sh
index 85e412ef5..602e84c6b 100644
--- a/scripts/ao-pr-poller-resume-tests.sh
+++ b/scripts/ao-pr-poller-resume-tests.sh
@@ -160,12 +160,70 @@ test_check_session_idle() {
     fi
 }
 
+#######################################
+# Test: cleanup_zombie_worktree removes worktrees at /tmp-style paths
+# Regression test for bug where ^path grep never matched porcelain output,
+# leaving /private/tmp/smartclaw-* worktrees stranded every cycle.
+#######################################
+test_cleanup_zombie_worktree_tmp_path() {
+    log_test "=== Test: cleanup_zombie_worktree removes /tmp-style worktrees ==="
+
+    if ! type cleanup_zombie_worktree >/dev/null 2>&1; then
+        fail "cleanup_zombie_worktree not found"
+        return
+    fi
+
+    local repo_path
+    repo_path=$(mktemp -d); repo_path=$(cd "$repo_path" && pwd -P)
+    local wt_path
+    wt_path=$(mktemp -d); wt_path=$(cd "$wt_path" && pwd -P)
+    local test_branch="fix/test-cleanup-$(date +%s)"
+
+    # Init a bare repo and a worktree at a /tmp path (simulates AO's old behavior)
+    git -C "$repo_path" init -q -b main
+    git -C "$repo_path" -c user.name="Test" -c user.email="test@test.com" commit --allow-empty -m "init" -q
+    git -C "$repo_path" branch "$test_branch"
+    git -C "$repo_path" worktree add "$wt_path" "$test_branch" -q 2>/dev/null
+
+    if ! git -C "$repo_path" worktree list --porcelain | grep -q "worktree $wt_path"; then
+        fail "setup: worktree not registered" "path: $wt_path"
+        rm -rf "$repo_path" "$wt_path"
+        return
+    fi
+
+    # Override repo_clone_path to return our test repo
+    repo_clone_path() { echo "$repo_path"; }
+    repo_to_ao_project() { echo ""; }
+
+    cleanup_zombie_worktree "$test_branch" "test/repo"
+
+    # Verify the worktree was actually removed
+    if git -C "$repo_path" worktree list --porcelain 2>/dev/null | grep -q "worktree $wt_path"; then
+        fail "cleanup_zombie_worktree left /tmp worktree registered in git" "wt: $wt_path"
+    else
+        pass "cleanup_zombie_worktree removed /tmp-style worktree from git"
+    fi
+
+    if [[ -d "$wt_path" ]]; then
+        fail "cleanup_zombie_worktree left /tmp worktree directory on disk" "dir: $wt_path"
+    else
+        pass "cleanup_zombie_worktree removed /tmp-style worktree directory"
+    fi
+
+    rm -rf "$repo_path" "$wt_path" 2>/dev/null || true
+    # Restore overrides
+    unset -f repo_clone_path repo_to_ao_project 2>/dev/null || true
+}
+
 # Run all tests
 main() {
     log_test "========================================="
     log_test "Running ao-pr-poller resume logic TDD tests"
     log_test "========================================="
-    
+
+    # NOTE: tests below are TDD stubs — functions they test are not yet implemented
+    # in ao-pr-poller.sh (find_session_for_branch, resume_session, check_session_idle).
+    # They are expected to fail until those features are added; do not count as regressions.
     test_branch_checked_out_removed
     test_find_session_for_branch
     test_is_agent_running_in_session
@@ -173,11 +231,14 @@ main() {
     test_resume_session
     test_resume_logic_in_main_loop
     test_check_session_idle
-    
+
+    # Active test — exercises real cleanup_zombie_worktree path fixed in orch-tzc
+    test_cleanup_zombie_worktree_tmp_path
+
     log_test "========================================="
     log_test "Results: $TESTS_PASSED passed, $TESTS_FAILED failed (total: $TESTS_RUN)"
     log_test "========================================="
-    
+
     [[ $TESTS_FAILED -eq 0 ]]
 }
 
diff --git a/scripts/ao-pr-poller.sh b/scripts/ao-pr-poller.sh
index 4493867ea..55eddd0c1 100755
--- a/scripts/ao-pr-poller.sh
+++ b/scripts/ao-pr-poller.sh
@@ -248,17 +248,22 @@ cleanup_zombie_worktree() {
         tmux kill-session -t "$tmux_session" 2>/dev/null || true
     done
     
-    # Remove git worktree
-    if [[ -n "$clone_path" && -d "$clone_path/.git/worktrees" ]]; then
-        local wt_path
-        for wt_path in "$clone_path/.git/worktrees"/*; do
-            [[ -d "$wt_path" ]] || continue
-            if git -C "$clone_path" worktree list --porcelain 2>/dev/null | grep -q "^path $wt_path" && \
-               git -C "$clone_path" worktree list --porcelain 2>/dev/null | grep -A1 "^path $wt_path" | grep -q "refs/heads/$branch"; then
-                log "Removing zombie worktree: $wt_path"
-                git -C "$clone_path" worktree remove "$wt_path" --force 2>/dev/null || true
-            fi
-        done
+    # Remove git worktree — find actual checkout path via porcelain output, not .git/worktrees metadata
+    # Bug fixed: porcelain uses "worktree /path" not "path /path"; also need the checkout path not metadata dir
+    # Safety: skip the first block (main worktree = clone_path) to prevent accidental repo deletion
+    # Safety: never rm -rf; only use git worktree remove --force which refuses to delete the main worktree
+    if [[ -n "$clone_path" && -d "$clone_path" ]]; then
+        local actual_wt_path
+        # Parse porcelain: skip the first block (main worktree), then find matching branch
+        actual_wt_path=$(git -C "$clone_path" worktree list --porcelain 2>/dev/null \
+            | awk -v branch="refs/heads/$branch" -v main="$clone_path" '
+                /^worktree / { wt = substr($0, 10); is_main = (wt == main) }
+                !is_main && $0 == "branch " branch { print wt }
+            ')
+        if [[ -n "$actual_wt_path" ]]; then
+            log "Removing zombie worktree: $actual_wt_path"
+            git -C "$clone_path" worktree remove "$actual_wt_path" --force 2>/dev/null || true
+        fi
     fi
     
     # Remove AO worktree directories matching this branch
@@ -289,16 +294,25 @@ cleanup_zombie_sessions() {
     log "Scanning for zombie tmux sessions..."
     local cleaned=0
 
+    # jc-* sessions → smartclaw repo
     for session in $(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -E "^[0-9a-f]+-jc-" || true); do
         if ! is_agent_alive_in_session "$session"; then
-            # Extract branch: strip the machine prefix (everything before first jc-)
             local branch="${session#*-}"
-            log "Found zombie session: $session (branch: $branch)"
+            log "Found zombie jc- session: $session (branch: $branch)"
             cleanup_zombie_worktree "$branch" "jleechanorg/smartclaw"
             cleaned=$((cleaned + 1))
         fi
     done
 
+    # ao-* sessions → agent-orchestrator repo (rate-limit failures leave these stranded)
+    for session in $(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -E "^[0-9a-f]+-ao-[0-9]+" || true); do
+        if ! is_agent_alive_in_session "$session"; then
+            log "Found zombie ao- session: $session — killing (no worktree cleanup needed)"
+            tmux kill-session -t "$session" 2>/dev/null || true
+            cleaned=$((cleaned + 1))
+        fi
+    done
+
     [[ $cleaned -gt 0 ]] && log "Cleaned up $cleaned zombie sessions"
 }
 
