# SmartClaw Environment Variables
# Copy to .env and fill in real values

# Slack integration
SMARTCLAW_DM_CHANNEL=          # Slack DM channel ID for owner notifications
SMARTCLAW_TRIGGER_CHANNEL=     # Slack channel ID for trigger/thread replies
SMARTCLAW_OWNER_USER_ID=       # Slack user ID of the repo owner
SLACK_BOT_TOKEN=               # xoxb-... Slack bot token
SLACK_USER_TOKEN=              # xoxp-... Slack user token (for posting as user)

# GitHub
GITHUB_TOKEN=                  # ghp_... or fine-grained PAT
SMARTCLAW_AUTHORIZED_REVIEWERS=reviewer-agent[bot]  # comma-separated GitHub logins authorized for merge verdicts

# OpenClaw gateway
GATEWAY_TOKEN=                 # Local gateway auth token
HOOKS_TOKEN=                   # Webhook auth token
SLACK_APP_TOKEN=               # xapp-... Slack app-level token
