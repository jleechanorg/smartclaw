# SmartClaw Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control

# === Slack Configuration ===
# Get from Slack app OAuth & Permissions
OPENCLAW_SLACK_BOT_TOKEN="xoxb-your-bot-token"
OPENCLAW_SLACK_APP_TOKEN="xapp-your-app-token"
SLACK_USER_TOKEN="xoxp-your-user-token"

# === Slack Identity ===
# Find via: right-click user in Slack → Copy link → extract ID
JLEECHAN_SLACK_USER_ID="U09GH5BR3QU"
OPENCLAW_BOT_USER_ID="U0AEZC7RX1Q"

# === Slack Channels ===
# Find via: right-click channel → Copy link → extract ID
AGENTO_CHANNEL="C0AJQ5M0A0Y"
SLACK_TEST_CHANNEL="C0AKALZ4CKW"
JLEECHAN_DM_CHANNEL="D0AFTLEJGJU"

# === Gateway ===
OPENCLAW_URL="http://127.0.0.1:18789"
OPENCLAW_GATEWAY_TOKEN="your-gateway-token"

# === Agent Orchestrator ===
# Get from: ao token show
OPENCLAW_AO_HOOK_TOKEN="your-ao-hook-token"
