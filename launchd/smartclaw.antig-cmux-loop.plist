<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>ai.smartclaw.antig-cmux-loop</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>${HOME}/.smartclaw/scripts/antig-cmux-loop.sh</string>
    </array>
    <key>StartInterval</key>
    <integer>600</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${HOME}/.smartclaw/logs/antig-cmux-loop.log</string>
    <key>StandardErrorPath</key>
    <string>${HOME}/.smartclaw/logs/antig-cmux-loop.err</string>
    <key>LowPriorityIO</key>
    <true/>
</dict>
</plist>
